# Copy the values you need into `.env.dev` or `.env.prod`.
# `dev` is for local development. `prod` is for the live deployment build.

# Host ports for the frontend containers.
FRONTEND_DEV_PORT=8080
FRONTEND_PROD_PORT=4173

# Backend target used by the Vite dev proxy.
DEV_PROXY_TARGET=http://127.0.0.1:3000

# Optional absolute backend URLs.
# Leave these blank in local development to use the Vite proxy configured in `vite.config.ts`.
VITE_STOCK_ASSETS_API_BASE_URL=
VITE_STOCK_FACTOR_COEFVEC_API_BASE_URL=
VITE_STOCK_FUNDAMENTAL_API_BASE_URL=

# Legacy endpoint used by `src/API/fetchPerformance.ts`.
# Add this only if that API helper is revived or wired back into the UI.
VITE_LOCAL_BACKEND_SERVER=
