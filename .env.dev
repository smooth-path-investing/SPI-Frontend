# Local development release mode.
# `npm run dev` and `npm run build:dev` load this file.

# Host port published by the frontend dev container.
FRONTEND_DEV_PORT=8080

# Backend target used by the Vite dev proxy.
DEV_PROXY_TARGET=http://127.0.0.1:3000

# Leave stock API base URLs blank in dev so requests use the Vite proxy in `vite.config.ts`.
VITE_STOCK_ASSETS_API_BASE_URL=
VITE_STOCK_FACTOR_COEFVEC_API_BASE_URL=
VITE_STOCK_FUNDAMENTAL_API_BASE_URL=

# Legacy local backend used by `src/API/fetchPerformance.ts`.
VITE_LOCAL_BACKEND_SERVER=http://localhost:5050
